{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:monorepos",
    "group:recommended",
    ":semanticCommits"
  ],
  "schedule": [
    "before 9am on monday"
  ],
  "timezone": "Europe/Amsterdam",
  "configMigration": true,
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Automerge minor and patch",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Do not automerge major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Group Rust minor/patch",
      "matchManagers": [
        "cargo"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "rust-dependencies"
    },
    {
      "description": "Group React ecosystem",
      "matchManagers": [
        "npm"
      ],
      "groupName": "react",
      "matchPackageNames": [
        "/^react/",
        "/^@types/react/"
      ]
    },
    {
      "description": "Group Next.js ecosystem",
      "matchManagers": [
        "npm"
      ],
      "groupName": "nextjs",
      "matchPackageNames": [
        "/^next/"
      ]
    },
    {
      "description": "Group tooling",
      "matchManagers": [
        "npm"
      ],
      "matchPackageNames": [
        "turbo",
        "@biomejs/biome",
        "ultracite",
        "typescript",
        "/^turbo/"
      ],
      "groupName": "tooling"
    },
    {
      "description": "Group remaining npm minor/patch",
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "npm-minor-patch"
    },
    {
      "description": "Group Docker updates",
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "docker"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    }
  ]
}
